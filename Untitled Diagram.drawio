        <mxCell id="icB7A3Fk58bX-gcXmao--2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="SmnWdv0_qvQ2UJ-YlQ_u-3" target="SmnWdv0_qvQ2UJ-YlQ_u-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="SmnWdv0_qvQ2UJ-YlQ_u-3" value="firstly we need to know what is process&amp;nbsp;&lt;div style=&quot;&quot;&gt;in a process is in section of action preform&amp;nbsp;in code&amp;nbsp; for a specific task&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-810" y="20" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="SmnWdv0_qvQ2UJ-YlQ_u-4" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Fork&lt;/h1&gt;&lt;p&gt;first the fork function is in function to duplicate the process the u may work with it.&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;it create in new process into the process u may used in the sec process are called the child process&lt;/span&gt;&lt;/p&gt;&lt;p&gt;the Return values of the fork is an integer that is :&amp;nbsp;&lt;/p&gt;&lt;p&gt;positive val if -- process are created this value is the value of the process ID of the new child&amp;nbsp;&lt;/p&gt;&lt;p&gt;zero if --&amp;nbsp; newly created child process&lt;/p&gt;&lt;p&gt;&lt;font&gt;negative&lt;/font&gt; val if --&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;the chill creation of process was unsuccessful&lt;/span&gt;&lt;/p&gt;&lt;p&gt;and the fork is in a &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 0, 0));&quot;&gt;system call&lt;/font&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-480" y="40" width="450" height="320" as="geometry" />
        </mxCell>
        <mxCell id="icB7A3Fk58bX-gcXmao--3" value="the main idea of pipe that we use it for a&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(221, 255, 75));&quot;&gt;&lt;i&gt;example : cat file.txt | grep de_quoi&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;as this base example that the function cat it used as input for the second function grep&amp;nbsp;&lt;/div&gt;&lt;div&gt;so this is basically in pipe that we take&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="80" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="icB7A3Fk58bX-gcXmao--7" value="FROM HERE WE GO TO DUPLICATE THE PROCESSE&amp;nbsp;" style="whiteSpace=wrap;html=1;shape=partialRectangle;top=0;left=0;bottom=1;right=0;points=[[0,1],[1,1]];fillColor=none;align=center;verticalAlign=bottom;routingCenterY=0.5;snapToPoint=1;recursiveResize=0;autosize=1;treeFolding=1;treeMoving=1;newEdgeStyle={&quot;edgeStyle&quot;:&quot;entityRelationEdgeStyle&quot;,&quot;startArrow&quot;:&quot;none&quot;,&quot;endArrow&quot;:&quot;none&quot;,&quot;segment&quot;:10,&quot;curved&quot;:1,&quot;sourcePerimeterSpacing&quot;:0,&quot;targetPerimeterSpacing&quot;:0};" vertex="1" parent="1">
